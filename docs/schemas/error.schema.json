        "embedding.preset_revision_mismatch",
        "embedding.provider_unavailable",
        "embedding.quantization_contract_mismatch",
        "embedding.qwen_device_unavailable",
        "embedding.qwen_inference_failed",
        "embedding.qwen_runtime_unavailable",
        "embedding.qwen_snapshot_invalid",
        "embedding.qwen_tokenizer_failed",
        "embedding.source_snapshot_incomplete",
        "embedding.token_unavailable",
        "embedding.tokenizer_artifact_too_large",
        "embedding.tokenizer_failed",
        "embedding.tokenizer_init_failed",
        "embedding.tokenizer_unmappable_offset",
        "embedding.vector_capability_unavailable",
        "embedding.vector_count_mismatch",
        "embedding.vector_dimension_mismatch",
        "model.artifact_invalid",
        "model.artifact_missing",
        "model.download_failed",
        "model.install_failed",
        "model.not_installed",
        "model.provider_unavailable",
        "model.snapshot_invalid",
        "model.unknown",
        "source.not_found",
        "source.tombstoned",
        "source.outside_effective_scope",
        "purge.lifecycle_candidate_missing",
        "purge.allowlist_reconciliation_required",
        "purge.conflicting_triggers",
        "purge.successor_blocked",
        "purge.successor_repair_required",
        "purge.successor_repair_state_invalid",
        "purge.successor_snapshot_pending",
        "purge.retry_failed",
        "purge.tombstone_missing",
        "purge.index_path_invalid",
        "purge.index_root_invalid",
        "purge.invalid_target",
        "purge.failed",
        "purge.write_fenced",
        "purge.read_fenced",
        "publication.cas_conflict",
