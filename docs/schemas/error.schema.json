{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/error.schema.json",
  "title": "qgh structured error",
  "type": "object",
  "required": ["code", "message", "details", "hint", "retryable", "exit_code"],
  "properties": {
    "code": {
      "$ref": "#/$defs/error_code"
    },
    "message": {
      "type": "string"
    },
    "details": {
      "type": "object"
    },
    "hint": {
      "type": ["string", "null"]
    },
    "retryable": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "enum": [2, 3, 4, 5, 6, 70]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "error_code": {
      "type": "string",
      "enum": [
        "config.invalid",
        "config.no_matching_profile",
        "config.ambiguous_profile",
        "config.invalid_repo_policy",
        "config.no_git_worktree",
        "config.git_remote_unavailable",
        "config.unsupported_git_remote",
        "config.repo_policy_exists",
        "validation.cli",
        "validation.missing_init_value",
        "validation.init_requires_input",
        "validation.init_cancelled",
        "validation.invalid_init_answer",
        "validation.invalid_query",
        "validation.invalid_issue_number",
        "validation.invalid_host",
        "validation.invalid_url",
        "validation.invalid_repo",
        "validation.invalid_state",
        "validation.invalid_token_source",
        "validation.window_requires_recent",
        "validation.backfill_conflicts",
        "validation.requires_backfill",
        "validation.repo_required",
        "validation.batch_size",
        "validation.mcp",
        "validation.unsupported_filter",
        "validation.unsupported_source_type",
        "validation.ambiguous_locator",
        "freshness.stale",
        "auth.token_unavailable",
        "github.request_failed",
        "github.invalid_issue_json",
        "github.invalid_comment_json",
        "github.confirmed_lifecycle_requires_typed_handling",
        "sync.commit_page_failed",
        "sync.transfer_cycle",
        "sync.transfer_chain_too_long",
        "validation.lifecycle_failed",
        "embedding.source_snapshot_missing",
        "source.not_found",
        "source.tombstoned",
        "source.outside_effective_scope",
        "purge.lifecycle_candidate_missing",
        "purge.conflicting_triggers",
        "purge.successor_blocked",
        "purge.successor_repair_required",
        "purge.successor_repair_state_invalid",
        "purge.successor_snapshot_pending",
        "purge.retry_failed",
        "purge.tombstone_missing",
        "purge.index_path_invalid",
        "purge.index_root_invalid",
        "purge.invalid_target",
        "purge.failed",
        "purge.write_fenced",
        "purge.read_fenced",
        "publication.cas_conflict",
        "publication.embedding_not_ready",
        "publication.successor_snapshot_required",
        "publication.tantivy_artifact_not_ready",
        "publication.tantivy_generation_missing",
        "storage.failure",
        "index.failure",
        "internal.failure"
      ]
    }
  }
}
