{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/status-output.schema.json",
  "title": "qgh status data",
  "type": "object",
  "required": [
    "profile_id",
    "freshness",
    "coverage",
    "github",
    "paths",
    "sources",
    "database",
    "index",
    "sync",
    "reconciliation",
    "resolution",
    "privacy"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "freshness": {
      "$ref": "#/$defs/freshness"
    },
    "coverage": {
      "$ref": "#/$defs/coverage"
    },
    "github": {
      "$ref": "#/$defs/github"
    },
    "paths": {
      "type": "object"
    },
    "sources": {
      "$ref": "#/$defs/sources"
    },
    "database": {
      "$ref": "#/$defs/database"
    },
    "index": {
      "$ref": "#/$defs/index"
    },
    "sync": {
      "type": "object"
    },
    "reconciliation": {
      "type": "object"
    },
    "resolution": {
      "$ref": "#/$defs/resolution"
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "github": {
      "type": "object",
      "required": ["host", "api_base_url", "web_base_url"],
      "properties": {
        "host": {
          "type": "string"
        },
        "api_base_url": {
          "type": "string"
        },
        "web_base_url": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "object",
      "required": ["issue_count", "comment_count", "tombstone_count"],
      "properties": {
        "issue_count": {
          "type": "integer",
          "minimum": 0
        },
        "comment_count": {
          "type": "integer",
          "minimum": 0
        },
        "tombstone_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "database": {
      "type": "object",
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "const": "qgh.db.v1"
        }
      },
      "additionalProperties": false
    },
    "index": {
      "type": "object",
      "required": ["active_generation", "dirty_task_count"],
      "properties": {
        "active_generation": {
          "type": "integer",
          "minimum": 0
        },
        "dirty_task_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "required": [
        "classification",
        "default_network_egress",
        "hosted_provider_egress",
        "local_paths_may_contain_private_content",
        "single_user_permissions"
      ],
      "properties": {
        "classification": {
          "const": "sensitive_derivative_data"
        },
        "default_network_egress": {
          "const": "configured_github_host_only"
        },
        "hosted_provider_egress": {
          "const": "disabled"
        },
        "local_paths_may_contain_private_content": {
          "const": true
        },
        "single_user_permissions": {
          "const": "0600_files_0700_dirs_where_supported"
        }
      },
      "additionalProperties": false
    },
    "freshness": {
      "type": "object",
      "required": [
        "decision",
        "remote_checked",
        "snapshot_age_seconds",
        "max_age_seconds"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["fresh", "stale_warn", "stale_fail", "never_synced"]
        },
        "remote_checked": {
          "const": false
        },
        "snapshot_age_seconds": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "max_age_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "mode",
        "open_cursor",
        "history_cursor",
        "open_backfill_complete",
        "historical_backfill_complete",
        "oldest_synced_updated_at",
        "recent_bootstrap_floor",
        "next_backfill_window_hint"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["partial", "complete"],
          "description": "Derived from the completion flags; complete iff both backfills are complete. Never set directly."
        },
        "open_cursor": {
          "type": ["string", "null"]
        },
        "history_cursor": {
          "type": ["string", "null"]
        },
        "open_backfill_complete": {
          "type": "boolean"
        },
        "historical_backfill_complete": {
          "type": "boolean"
        },
        "oldest_synced_updated_at": {
          "type": ["string", "null"]
        },
        "recent_bootstrap_floor": {
          "type": ["string", "null"],
          "description": "Fixed bootstrap_start - lookback boundary. Recent lookback is acceleration, not a corpus boundary."
        },
        "next_backfill_window_hint": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "resolution": {
      "type": "object",
      "required": [
        "profile_id",
        "profile_source",
        "effective_repo_scope",
        "repo_source",
        "repo_policy_path",
        "allowlist_match_count"
      ],
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "profile_source": {
          "type": "string",
          "enum": ["cli", "env", "single_match"]
        },
        "effective_repo_scope": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "repo_source": {
          "type": ["string", "null"],
          "enum": ["cli", "repo_policy", "git_remote", "command", null]
        },
        "repo_policy_path": {
          "type": ["string", "null"]
        },
        "allowlist_match_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
