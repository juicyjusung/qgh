{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/status-output.schema.json",
  "title": "qgh status data",
  "type": "object",
  "required": [
    "profile_id",
    "github",
    "paths",
    "sources",
    "database",
    "index",
    "sync",
    "reconciliation",
    "resolution",
    "privacy"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "github": {
      "type": "object"
    },
    "paths": {
      "type": "object"
    },
    "sources": {
      "type": "object"
    },
    "database": {
      "type": "object"
    },
    "index": {
      "type": "object"
    },
    "sync": {
      "type": "object"
    },
    "reconciliation": {
      "type": "object"
    },
    "resolution": {
      "$ref": "#/$defs/resolution"
    },
    "privacy": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "resolution": {
      "type": "object",
      "required": [
        "profile_id",
        "profile_source",
        "effective_repo_scope",
        "repo_source",
        "repo_policy_path",
        "allowlist_match_count"
      ],
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "profile_source": {
          "type": "string",
          "enum": ["cli", "env", "single_match"]
        },
        "effective_repo_scope": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "repo_source": {
          "type": ["string", "null"],
          "enum": ["cli", "repo_policy", "git_remote", "command", null]
        },
        "repo_policy_path": {
          "type": ["string", "null"]
        },
        "allowlist_match_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
