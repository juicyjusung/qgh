{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/status-output.schema.json",
  "title": "qgh status data",
  "type": "object",
  "required": [
    "profile_id",
    "freshness",
    "coverage",
    "github",
    "paths",
    "sources",
    "database",
    "index",
    "sync",
    "reconciliation",
    "purge",
    "resolution",
    "privacy"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "freshness": {
      "$ref": "#/$defs/freshness"
    },
    "coverage": {
      "$ref": "#/$defs/coverage"
    },
    "embedding": {
      "$ref": "#/$defs/embedding"
    },
    "github": {
      "$ref": "#/$defs/github"
    },
    "paths": {
      "$ref": "#/$defs/paths"
    },
    "sources": {
      "$ref": "#/$defs/sources"
    },
    "database": {
      "$ref": "#/$defs/database"
    },
    "index": {
      "$ref": "#/$defs/index"
    },
    "sync": {
      "$ref": "#/$defs/sync"
    },
    "reconciliation": {
      "$ref": "#/$defs/reconciliation"
    },
    "purge": {
      "$ref": "#/$defs/purge"
    },
    "resolution": {
      "$ref": "#/$defs/resolution"
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "purge": {
      "type": "object",
      "required": [
        "pending_count",
        "successor_repair_required",
        "retrieval_blocked",
        "target_kinds",
        "triggers",
        "current_stages",
        "failure_stages"
      ],
      "properties": {
        "pending_count": {
          "type": "integer",
          "minimum": 0
        },
        "successor_repair_required": {
          "type": "boolean"
        },
        "retrieval_blocked": {
          "type": "boolean"
        },
        "target_kinds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["source", "issue", "repository"]
          }
        },
        "triggers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "confirmed_delete",
              "confirmed_tombstone",
              "permission_loss",
              "allowlist_removal"
            ]
          }
        },
        "current_stages": {
          "$ref": "#/$defs/purge_stages"
        },
        "failure_stages": {
          "$ref": "#/$defs/purge_stages"
        }
      },
      "additionalProperties": false
    },
    "purge_stages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["secure_delete", "tantivy", "storage", "wal_checkpoint", "finalize"]
      }
    },
    "github": {
      "type": "object",
      "required": ["host", "api_base_url", "web_base_url"],
      "properties": {
        "host": {
          "type": "string"
        },
        "api_base_url": {
          "type": "string"
        },
        "web_base_url": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "required": [
        "config",
        "profile_data",
        "database",
        "tantivy_index",
        "cache",
        "logs"
      ],
      "properties": {
        "config": {
          "type": "string"
        },
        "profile_data": {
          "type": "string"
        },
        "database": {
          "type": "string"
        },
        "tantivy_index": {
          "type": "string"
        },
        "cache": {
          "type": "string"
        },
        "logs": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "object",
      "required": ["issue_count", "comment_count", "tombstone_count"],
      "properties": {
        "issue_count": {
          "type": "integer",
          "minimum": 0
        },
        "comment_count": {
          "type": "integer",
          "minimum": 0
        },
        "tombstone_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "database": {
      "type": "object",
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "const": "qgh.db.v1"
        }
      },
      "additionalProperties": false
    },
    "index": {
      "type": "object",
      "required": ["active_generation", "dirty_task_count"],
      "properties": {
        "active_generation": {
          "type": "integer",
          "minimum": 0
        },
        "dirty_task_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "sync": {
      "type": "object",
      "required": ["last_sync_at", "cursors", "backoff", "scheduler"],
      "properties": {
        "last_sync_at": {
          "type": ["string", "null"]
        },
        "cursors": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/sync_cursor"
          }
        },
        "backoff": {
          "anyOf": [
            {
              "$ref": "#/$defs/sync_backoff"
            },
            {
              "type": "null"
            }
          ]
        },
        "scheduler": {
          "$ref": "#/$defs/sync_scheduler"
        }
      },
      "additionalProperties": false
    },
    "sync_cursor": {
      "type": "object",
      "required": ["watermark", "has_etag"],
      "properties": {
        "watermark": {
          "type": ["string", "null"]
        },
        "has_etag": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "sync_backoff": {
      "type": "object",
      "required": [
        "reason",
        "scope",
        "retry_after_seconds",
        "reset_at",
        "observed_at",
        "last_successful_sync"
      ],
      "properties": {
        "reason": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "retry_after_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "reset_at": {
          "type": ["string", "null"]
        },
        "observed_at": {
          "type": "string"
        },
        "last_successful_sync": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "sync_scheduler": {
      "type": "object",
      "required": ["max_in_flight_requests", "hard_cap"],
      "properties": {
        "max_in_flight_requests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "hard_cap": {
          "const": 16
        }
      },
      "additionalProperties": false
    },
    "reconciliation": {
      "type": "object",
      "required": [
        "last_full_at",
        "age_days",
        "stale",
        "stale_warning",
        "estimated_api_cost_class",
        "last_checked_source_count",
        "last_tombstoned_count",
        "last_estimated_api_cost_class"
      ],
      "properties": {
        "last_full_at": {
          "type": ["string", "null"]
        },
        "age_days": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "stale": {
          "type": "boolean"
        },
        "stale_warning": {
          "enum": ["reconciliation.stale", null]
        },
        "estimated_api_cost_class": {
          "$ref": "#/$defs/api_cost_class"
        },
        "last_checked_source_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "last_tombstoned_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "last_estimated_api_cost_class": {
          "anyOf": [
            {
              "$ref": "#/$defs/api_cost_class"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "api_cost_class": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "privacy": {
      "type": "object",
      "required": [
        "classification",
        "default_network_egress",
        "hosted_provider_egress",
        "local_paths_may_contain_private_content",
        "single_user_permissions"
      ],
      "properties": {
        "classification": {
          "const": "sensitive_derivative_data"
        },
        "default_network_egress": {
          "const": "configured_github_host_only"
        },
        "hosted_provider_egress": {
          "const": "disabled"
        },
        "local_paths_may_contain_private_content": {
          "const": true
        },
        "single_user_permissions": {
          "const": "0600_files_0700_dirs_where_supported"
        }
      },
      "additionalProperties": false
    },
    "freshness": {
      "type": "object",
      "required": [
        "decision",
        "remote_checked",
        "snapshot_age_seconds",
        "max_age_seconds"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["fresh", "stale_warn", "stale_fail", "never_synced"]
        },
        "remote_checked": {
          "const": false
        },
        "snapshot_age_seconds": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "max_age_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "mode",
        "open_cursor",
        "history_cursor",
        "open_backfill_complete",
        "historical_backfill_complete",
        "oldest_synced_updated_at",
        "recent_bootstrap_floor",
        "next_backfill_window_hint"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["partial", "complete"],
          "description": "Derived from the completion flags; complete iff both backfills are complete. Never set directly."
        },
        "open_cursor": {
          "type": ["string", "null"]
        },
        "history_cursor": {
          "type": ["string", "null"]
        },
        "open_backfill_complete": {
          "type": "boolean"
        },
        "historical_backfill_complete": {
          "type": "boolean"
        },
        "oldest_synced_updated_at": {
          "type": ["string", "null"]
        },
        "recent_bootstrap_floor": {
          "type": ["string", "null"],
          "description": "Fixed bootstrap_start - lookback boundary. Recent lookback is acceleration, not a corpus boundary."
        },
        "next_backfill_window_hint": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "embedding": {
      "type": "object",
      "required": ["state", "coverage", "configured_model", "fingerprint"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["missing", "partial", "complete", "fingerprint_mismatch", "corrupt"]
        },
        "coverage": {
          "$ref": "#/$defs/embedding_coverage"
        },
        "configured_model": {
          "$ref": "#/$defs/embedding_configured_model"
        },
        "fingerprint": {
          "anyOf": [
            {
              "$ref": "#/$defs/embedding_fingerprint"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "embedding_coverage": {
      "type": "object",
      "required": [
        "total_chunks",
        "completed_chunks",
        "missing_chunks",
        "mismatched_chunks"
      ],
      "properties": {
        "total_chunks": {
          "type": "integer",
          "minimum": 0
        },
        "completed_chunks": {
          "type": "integer",
          "minimum": 0
        },
        "missing_chunks": {
          "type": "integer",
          "minimum": 0
        },
        "mismatched_chunks": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "embedding_configured_model": {
      "type": "object",
      "required": ["provider", "model", "model_id", "model_revision", "model_path"],
      "properties": {
        "provider": {
          "enum": ["local"]
        },
        "model": {
          "type": ["string", "null"]
        },
        "model_id": {
          "type": "string"
        },
        "model_revision": {
          "type": ["string", "null"]
        },
        "model_path": {
          "type": ["string", "null"]
        },
        "device": {
          "type": "string",
          "enum": ["auto", "cpu", "metal"]
        },
        "runtime_profile": {
          "type": "string",
          "enum": ["cpu_f32", "metal_f16"]
        }
      },
      "additionalProperties": false
    },
    "embedding_fingerprint": {
      "type": "object",
      "required": [
        "hash",
        "schema_version",
        "provider",
        "model_id",
        "model_revision",
        "dimension",
        "pooling",
        "query_prefix",
        "chunker_version",
        "source_schema_version",
        "matches_config"
      ],
      "properties": {
        "hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "schema_version": {
          "const": "qgh.embedding_fingerprint.v1"
        },
        "provider": {
          "enum": ["local"]
        },
        "model_id": {
          "type": "string"
        },
        "model_revision": {
          "type": "string"
        },
        "dimension": {
          "type": "integer",
          "minimum": 1
        },
        "pooling": {
          "enum": ["cls", "mean", "last_token"]
        },
        "query_prefix": {
          "type": "string"
        },
        "chunker_version": {
          "type": "string"
        },
        "source_schema_version": {
          "type": "string"
        },
        "matches_config": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "resolution": {
      "type": "object",
      "required": [
        "profile_id",
        "profile_source",
        "effective_repo_scope",
        "repo_source",
        "repo_policy_path",
        "allowlist_match_count"
      ],
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "profile_source": {
          "type": "string",
          "enum": ["cli", "env", "single_match"]
        },
        "effective_repo_scope": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "repo_source": {
          "type": ["string", "null"],
          "enum": ["cli", "repo_policy", "git_remote", "command", null]
        },
        "repo_policy_path": {
          "type": ["string", "null"]
        },
        "allowlist_match_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
