{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/query-result.schema.json",
  "title": "qgh query response",
  "type": "object",
  "required": ["profile_id", "result_filtering", "results"],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "result_filtering": {
      "type": "object",
      "required": ["unresolvable_hits"],
      "properties": {
        "unresolvable_hits": {
          "type": "integer",
          "minimum": 0,
          "description": "Index hits excluded because they could not round-trip through get."
        }
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/query_result"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "query_result": {
      "type": "object",
      "required": [
        "source_id",
        "entity_type",
        "repo",
        "issue_number",
        "canonical_url",
        "snippet",
        "get_args",
        "parent_issue",
        "source_version",
        "ranking"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^qgh://github\\.com/(issue|issue-comment)/",
          "description": "Stable qgh source URI."
        },
        "entity_type": {
          "type": "string",
          "enum": ["issue", "issue_comment"]
        },
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "issue_number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "description": "Issue title when entity_type is issue."
        },
        "author": {
          "type": ["string", "null"],
          "description": "Comment author when entity_type is issue_comment."
        },
        "canonical_url": {
          "type": "string",
          "format": "uri"
        },
        "snippet": {
          "type": "string",
          "description": "Local preview, not citation evidence. Fetch get_args.source_id before citing."
        },
        "get_args": {
          "type": "object",
          "required": ["source_id"],
          "properties": {
            "source_id": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "parent_issue": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/parent_issue"
            }
          ]
        },
        "source_version": {
          "$ref": "#/$defs/source_version"
        },
        "ranking": {
          "$ref": "#/$defs/ranking"
        }
      },
      "additionalProperties": false
    },
    "parent_issue": {
      "type": "object",
      "required": ["source_id", "repo", "number", "title", "canonical_url"],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "number": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "canonical_url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "source_version": {
      "type": "object",
      "required": [
        "body_hash",
        "github_updated_at",
        "indexed_at",
        "sync_run_id",
        "lifecycle_state"
      ],
      "properties": {
        "body_hash": {
          "type": "string"
        },
        "github_updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "indexed_at": {
          "type": "string",
          "format": "date-time"
        },
        "sync_run_id": {
          "type": "string"
        },
        "lifecycle_state": {
          "type": "string",
          "enum": ["active"]
        }
      },
      "additionalProperties": false
    },
    "ranking": {
      "type": "object",
      "required": ["kind", "lexical_score"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["bm25", "exact"]
        },
        "lexical_score": {
          "type": ["number", "null"],
          "description": "Typed ordering signal. It is not confidence or probability."
        }
      },
      "additionalProperties": false
    }
  }
}
