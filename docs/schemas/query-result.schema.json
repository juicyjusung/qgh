{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/query-result.schema.json",
  "title": "qgh query response",
  "type": "object",
  "required": ["profile_id", "freshness", "coverage", "result_filtering", "results"],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "freshness": {
      "$ref": "#/$defs/freshness"
    },
    "coverage": {
      "$ref": "#/$defs/coverage"
    },
    "result_filtering": {
      "type": "object",
      "required": ["unresolvable_hits"],
      "properties": {
        "unresolvable_hits": {
          "type": "integer",
          "minimum": 0,
          "description": "Index hits excluded because they could not round-trip through get."
        }
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/query_result"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "query_result": {
      "type": "object",
      "required": [
        "source_id",
        "entity_type",
        "repo",
        "issue_number",
        "canonical_url",
        "snippet",
        "get_args",
        "parent_issue",
        "source_version",
        "ranking"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^qgh://[^/]+/(issue|issue-comment)/",
          "description": "Stable qgh source URI."
        },
        "entity_type": {
          "type": "string",
          "enum": ["issue", "issue_comment"]
        },
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "issue_number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "description": "Issue title when entity_type is issue."
        },
        "author": {
          "type": ["string", "null"],
          "description": "Comment author when entity_type is issue_comment."
        },
        "canonical_url": {
          "type": "string",
          "format": "uri"
        },
        "snippet": {
          "type": "string",
          "description": "Local preview, not citation evidence. Fetch get_args before citing."
        },
        "get_args": {
          "type": "object",
          "required": ["source_id", "profile_id"],
          "properties": {
            "source_id": {
              "type": "string"
            },
            "profile_id": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "parent_issue": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/parent_issue"
            }
          ]
        },
        "source_version": {
          "$ref": "#/$defs/source_version"
        },
        "ranking": {
          "$ref": "#/$defs/ranking"
        }
      },
      "additionalProperties": false
    },
    "freshness": {
      "type": "object",
      "required": [
        "decision",
        "remote_checked",
        "snapshot_age_seconds",
        "max_age_seconds"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["fresh", "stale_warn", "stale_fail", "never_synced"]
        },
        "remote_checked": {
          "const": false
        },
        "snapshot_age_seconds": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "max_age_seconds": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "mode",
        "open_cursor",
        "history_cursor",
        "open_backfill_complete",
        "historical_backfill_complete",
        "oldest_synced_updated_at",
        "recent_bootstrap_floor",
        "next_backfill_window_hint"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["partial", "complete"],
          "description": "Derived from the completion flags; complete iff both backfills are complete. Never set directly."
        },
        "open_cursor": {
          "type": ["string", "null"]
        },
        "history_cursor": {
          "type": ["string", "null"]
        },
        "open_backfill_complete": {
          "type": "boolean"
        },
        "historical_backfill_complete": {
          "type": "boolean"
        },
        "oldest_synced_updated_at": {
          "type": ["string", "null"]
        },
        "recent_bootstrap_floor": {
          "type": ["string", "null"],
          "description": "Fixed bootstrap_start - lookback boundary. Recent lookback is acceleration, not a corpus boundary."
        },
        "next_backfill_window_hint": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "parent_issue": {
      "type": "object",
      "required": ["source_id", "repo", "number", "title", "canonical_url"],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^qgh://[^/]+/issue/"
        },
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string"
        },
        "canonical_url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "source_version": {
      "type": "object",
      "required": [
        "body_hash",
        "github_updated_at",
        "indexed_at",
        "sync_run_id",
        "lifecycle_state"
      ],
      "properties": {
        "body_hash": {
          "type": "string"
        },
        "github_updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "indexed_at": {
          "type": "string",
          "format": "date-time"
        },
        "sync_run_id": {
          "type": "string"
        },
        "lifecycle_state": {
          "type": "string",
          "enum": ["active"]
        }
      },
      "additionalProperties": false
    },
    "ranking": {
      "type": "object",
      "required": ["kind", "lexical_score", "vector_distance"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["bm25", "vector", "exact"]
        },
        "lexical_score": {
          "type": ["number", "null"],
          "description": "Typed ordering signal. It is not confidence or probability."
        },
        "vector_distance": {
          "type": ["number", "null"],
          "description": "Vector ordering signal where lower is closer. It is not confidence or probability."
        }
      },
      "additionalProperties": false
    }
  }
}
