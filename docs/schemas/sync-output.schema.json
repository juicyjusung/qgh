{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/sync-output.schema.json",
  "title": "qgh sync data",
  "type": "object",
  "required": ["profile_id", "sync_state"],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "sync_state": {
      "type": "string",
      "enum": ["ok", "backoff", "skipped_fresh"]
    },
    "sync_run_id": {
      "type": "string"
    },
    "sync": {
      "type": "object"
    },
    "issues": {
      "type": "object"
    },
    "comments": {
      "type": "object"
    },
    "comment_listing": {
      "type": "object"
    },
    "cursors": {
      "type": "object"
    },
    "index": {
      "$ref": "#/$defs/index"
    },
    "reconciliation": {
      "type": "object"
    },
    "backoff": {
      "type": "object"
    },
    "backfill": {
      "type": "object"
    },
    "sources": {
      "$ref": "#/$defs/sources"
    },
    "scheduler": {
      "$ref": "#/$defs/scheduler"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "lifecycle": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "index": {
      "type": "object",
      "required": ["active_generation", "dirty_task_count"],
      "properties": {
        "active_generation": {
          "type": "integer",
          "minimum": 0
        },
        "dirty_task_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "object",
      "required": ["issue_count", "comment_count", "tombstone_count"],
      "properties": {
        "issue_count": {
          "type": "integer",
          "minimum": 0
        },
        "comment_count": {
          "type": "integer",
          "minimum": 0
        },
        "tombstone_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "scheduler": {
      "type": "object",
      "required": ["max_in_flight_requests", "hard_cap"],
      "properties": {
        "max_in_flight_requests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "hard_cap": {
          "const": 16
        }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["kind", "repo", "issue_number"],
      "properties": {
        "kind": {
          "const": "issue"
        },
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "issue_number": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
