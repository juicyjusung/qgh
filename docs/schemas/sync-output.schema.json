{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/sync-output.schema.json",
  "title": "qgh sync data",
  "type": "object",
  "required": ["profile_id", "sync_state"],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "sync_state": {
      "type": "string",
      "enum": ["ok", "backoff", "skipped_fresh"]
    },
    "sync_run_id": {
      "type": "string"
    },
    "sync": {
      "$ref": "#/$defs/sync"
    },
    "issues": {
      "$ref": "#/$defs/issues"
    },
    "comments": {
      "$ref": "#/$defs/comments"
    },
    "comment_listing": {
      "$ref": "#/$defs/comment_listing"
    },
    "cursors": {
      "$ref": "#/$defs/cursors"
    },
    "index": {
      "$ref": "#/$defs/index"
    },
    "reconciliation": {
      "$ref": "#/$defs/reconciliation"
    },
    "backoff": {
      "$ref": "#/$defs/backoff"
    },
    "backfill": {
      "$ref": "#/$defs/backfill"
    },
    "sources": {
      "$ref": "#/$defs/sources"
    },
    "scheduler": {
      "$ref": "#/$defs/scheduler"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "index": {
      "type": "object",
      "required": ["active_generation", "dirty_task_count"],
      "properties": {
        "active_generation": {
          "type": "integer",
          "minimum": 0
        },
        "dirty_task_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "sync": {
      "type": "object",
      "required": ["last_successful_sync"],
      "properties": {
        "last_successful_sync": {
          "type": ["string", "null"]
        },
        "snapshot_age_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "max_age_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "scheduler": {
          "$ref": "#/$defs/scheduler"
        }
      },
      "additionalProperties": false
    },
    "issues": {
      "type": "object",
      "required": ["fetched", "upserted", "skipped_pull_requests"],
      "properties": {
        "fetched": {
          "type": "integer",
          "minimum": 0
        },
        "upserted": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_pull_requests": {
          "type": "integer",
          "minimum": 0
        },
        "tombstoned": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "comments": {
      "type": "object",
      "required": ["fetched", "upserted"],
      "properties": {
        "fetched": {
          "type": "integer",
          "minimum": 0
        },
        "upserted": {
          "type": "integer",
          "minimum": 0
        },
        "added": {
          "type": "integer",
          "minimum": 0
        },
        "updated": {
          "type": "integer",
          "minimum": 0
        },
        "deleted": {
          "type": "integer",
          "minimum": 0
        },
        "tombstoned": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "comment_listing": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["per_issue", "repo_listing"]
        },
        "skipped_pr_comments": {
          "type": "integer",
          "minimum": 0
        },
        "deferred_comments": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "reconciliation": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "full", "recent", "targeted_issue"]
        },
        "checked_sources": {
          "type": "integer",
          "minimum": 0
        },
        "tombstoned_sources": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_api_cost_class": {
          "$ref": "#/$defs/api_cost_class"
        }
      },
      "additionalProperties": false
    },
    "backfill": {
      "type": "object",
      "required": [
        "issues",
        "comments",
        "skipped_pull_requests",
        "reached_end",
        "history_cursor",
        "historical_backfill_complete"
      ],
      "properties": {
        "issues": {
          "type": "integer",
          "minimum": 0
        },
        "comments": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_pull_requests": {
          "type": "integer",
          "minimum": 0
        },
        "reached_end": {
          "type": "boolean"
        },
        "history_cursor": {
          "type": ["string", "null"]
        },
        "historical_backfill_complete": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "backoff": {
      "type": "object",
      "required": [
        "reason",
        "scope",
        "retry_after_seconds",
        "reset_at",
        "observed_at",
        "last_successful_sync"
      ],
      "properties": {
        "reason": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "retry_after_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "reset_at": {
          "type": ["string", "null"]
        },
        "observed_at": {
          "type": "string"
        },
        "last_successful_sync": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "cursors": {
      "type": "object",
      "required": ["updated", "not_modified_endpoints", "watermarks"],
      "properties": {
        "updated": {
          "type": "integer",
          "minimum": 0
        },
        "not_modified_endpoints": {
          "type": "integer",
          "minimum": 0
        },
        "watermarks": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "null"]
          }
        }
      },
      "additionalProperties": false
    },
    "sources": {
      "type": "object",
      "required": ["issue_count", "comment_count", "tombstone_count"],
      "properties": {
        "issue_count": {
          "type": "integer",
          "minimum": 0
        },
        "comment_count": {
          "type": "integer",
          "minimum": 0
        },
        "tombstone_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "scheduler": {
      "type": "object",
      "required": ["max_in_flight_requests", "hard_cap"],
      "properties": {
        "max_in_flight_requests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "hard_cap": {
          "const": 16
        }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["kind", "repo", "issue_number"],
      "properties": {
        "kind": {
          "const": "issue"
        },
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$"
        },
        "issue_number": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "type": "object",
      "required": ["status", "reason", "http_status", "alias_chain"],
      "properties": {
        "status": {
          "type": "string"
        },
        "reason": {
          "type": ["string", "null"]
        },
        "http_status": {
          "type": ["integer", "null"],
          "minimum": 100,
          "maximum": 599
        },
        "alias_chain": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "api_cost_class": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    }
  }
}
