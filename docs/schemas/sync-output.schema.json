{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/sync-output.schema.json",
  "title": "qgh sync data",
  "type": "object",
  "required": ["profile_id", "sync_state"],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "sync_state": {
      "type": "string",
      "enum": ["ok", "backoff", "skipped_fresh"]
    },
    "sync_run_id": {
      "type": "string"
    },
    "sync": {
      "type": "object"
    },
    "issues": {
      "type": "object"
    },
    "comments": {
      "type": "object"
    },
    "comment_listing": {
      "type": "object"
    },
    "cursors": {
      "type": "object"
    },
    "index": {
      "type": "object"
    },
    "reconciliation": {
      "type": "object"
    },
    "backoff": {
      "type": "object"
    },
    "backfill": {
      "type": "object"
    },
    "sources": {
      "type": "object"
    },
    "scheduler": {
      "type": "object"
    },
    "target": {
      "type": "object"
    },
    "lifecycle": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
