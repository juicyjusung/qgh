{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/doctor-output.schema.json",
  "title": "qgh doctor data",
  "type": "object",
  "required": ["profile_id", "checks", "purge", "mcp", "resolution"],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "purge": {
      "$ref": "#/$defs/purge"
    },
    "mcp": {
      "type": "object",
      "required": ["doctor_exposed", "tools"],
      "properties": {
        "doctor_exposed": {
          "const": false
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["query", "get", "status"]
          }
        }
      },
      "additionalProperties": false
    },
    "resolution": {
      "$ref": "#/$defs/resolution"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "check": {
      "type": "object",
      "required": ["name", "ok"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "config",
            "file_permissions",
            "sqlite",
            "tantivy",
            "github_auth_reachability",
            "rate_limit_headers",
            "purge",
            "repo_policy",
            "profile_resolution"
          ]
        },
        "ok": {
          "type": "boolean"
        },
        "headers": {
          "$ref": "#/$defs/rate_limit_headers"
        },
        "path": {
          "type": ["string", "null"]
        },
        "repo": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "profile_id": {
          "type": "string"
        },
        "profile_source": {
          "type": "string",
          "enum": ["cli", "env", "single_match"]
        },
        "allowlist_match_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "purge": {
      "type": "object",
      "required": [
        "pending_count",
        "successor_repair_required",
        "retrieval_blocked",
        "target_kinds",
        "triggers",
        "current_stages",
        "failure_stages",
        "unmanaged_filesystem_backups"
      ],
      "properties": {
        "pending_count": {
          "type": "integer",
          "minimum": 0
        },
        "successor_repair_required": {
          "type": "boolean"
        },
        "retrieval_blocked": {
          "type": "boolean"
        },
        "target_kinds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["source", "issue", "repository"]
          }
        },
        "triggers": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "confirmed_delete",
              "confirmed_tombstone",
              "permission_loss",
              "allowlist_removal"
            ]
          }
        },
        "current_stages": {
          "$ref": "#/$defs/purge_stages"
        },
        "failure_stages": {
          "$ref": "#/$defs/purge_stages"
        },
        "unmanaged_filesystem_backups": {
          "const": "not_deleted_by_qgh"
        }
      },
      "additionalProperties": false
    },
    "purge_stages": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["secure_delete", "tantivy", "storage", "wal_checkpoint", "finalize"]
      }
    },
    "rate_limit_headers": {
      "type": "object",
      "required": ["x-ratelimit-remaining", "x-ratelimit-reset"],
      "properties": {
        "x-ratelimit-remaining": {
          "type": ["string", "null"]
        },
        "x-ratelimit-reset": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "resolution": {
      "type": "object",
      "required": [
        "profile_id",
        "profile_source",
        "effective_repo_scope",
        "repo_source",
        "repo_policy_path",
        "allowlist_match_count"
      ],
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "profile_source": {
          "type": "string",
          "enum": ["cli", "env", "single_match"]
        },
        "effective_repo_scope": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "repo_source": {
          "type": ["string", "null"],
          "enum": ["cli", "repo_policy", "git_remote", "command", null]
        },
        "repo_policy_path": {
          "type": ["string", "null"]
        },
        "allowlist_match_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
