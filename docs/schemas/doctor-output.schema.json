{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/juicyjusung/qgh/raw/main/docs/schemas/doctor-output.schema.json",
  "title": "qgh doctor data",
  "type": "object",
  "required": ["profile_id", "checks", "mcp", "resolution"],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "ok"],
        "properties": {
          "name": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    },
    "mcp": {
      "type": "object",
      "required": ["doctor_exposed", "tools"],
      "properties": {
        "doctor_exposed": {
          "const": false
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["query", "get", "status"]
          }
        }
      },
      "additionalProperties": false
    },
    "resolution": {
      "$ref": "#/$defs/resolution"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "resolution": {
      "type": "object",
      "required": [
        "profile_id",
        "profile_source",
        "effective_repo_scope",
        "repo_source",
        "repo_policy_path",
        "allowlist_match_count"
      ],
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "profile_source": {
          "type": "string",
          "enum": ["cli", "env", "single_match"]
        },
        "effective_repo_scope": {
          "type": ["string", "null"],
          "pattern": "^[^/]+/[^/]+$"
        },
        "repo_source": {
          "type": ["string", "null"],
          "enum": ["cli", "repo_policy", "command", null]
        },
        "repo_policy_path": {
          "type": ["string", "null"]
        },
        "allowlist_match_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
