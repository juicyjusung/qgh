{
  "schema_version": "qgh.release.v1",
  "contract": {
    "envelope_schema_version": "qgh.v1",
    "product_core": "CLI-first local retrieval with strict --json envelopes and SQLite/Tantivy behavior",
    "contract_source_of_truth": ["CLI args", "docs/schemas/*.schema.json", "local SQLite/Tantivy retrieval behavior"],
    "schema_object_closure": "released schema object shapes are closed by default; only envelope.data and error.details are documented extension points",
    "cli_commands": ["init", "sync", "query", "search", "get", "status", "doctor", "mcp"],
    "canonical_cli_commands": ["init", "sync", "query", "get", "status", "doctor"],
    "cli_aliases": {
      "search": "query"
    },
    "cli_only_commands": ["init", "sync", "doctor"],
    "human_output": "default successful CLI stdout is command-specific human summaries; pass --json for stable qgh.v1 envelopes",
    "primary_install_channel": {
      "manager": "homebrew",
      "command": "brew install juicyjusung/tap/qgh",
      "tap_repository": "juicyjusung/homebrew-tap",
      "formula": "qgh"
    },
    "release_artifact_origin": "GitHub Releases",
    "release_automation": "cargo-dist",
    "release_trigger": "Cargo.toml version bump commit plus matching vX.Y.Z tag push",
    "release_workflow": {
      "cargo_dist_version": "0.32.0",
      "config": "dist-workspace.toml",
      "workflow": ".github/workflows/release.yml",
      "homebrew_smoke_workflow": ".github/workflows/homebrew-smoke.yml",
      "checksum": "sha256",
      "ci_generated_config_policy": "allow-dirty ci preserves the actions/attest@v4 artifact-metadata permission",
      "post_announce_jobs": ["./homebrew-smoke"]
    },
    "release_targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu"
    ],
    "release_integrity_gate": [
      "artifact checksums",
      "Homebrew sha256",
      "GitHub Artifact Attestations",
      "actions/attest@v4 id-token/attestations/artifact-metadata permissions"
    ],
    "tap_publish_credential": {
      "secret_name": "HOMEBREW_TAP_TOKEN",
      "scope": "contents write on juicyjusung/homebrew-tap only"
    },
    "init_behavior": "top-level init previews inferred profile/repo defaults before writing; Enter/Y accepts, n customizes, EOF cancels without writes; init --yes and init -y apply the preset non-interactively; init repo is repo-policy-only",
    "init_yes_aliases": ["--yes", "-y"],
    "get_batch": {
      "max_source_ids": 20,
      "single_source_output": "backward compatible {profile_id, source}",
      "batch_output": "{profile_id, summary, lifecycle_check_policy, items}",
      "item_errors": ["source.not_found", "source.tombstoned", "source.outside_effective_scope"],
      "lifecycle_check_policy": "CLI opt-in verify_lifecycle; sequential max_in_flight_requests=1 when enabled; MCP get remains local-only"
    },
    "supported_token_sources": ["github_cli", "env"],
    "command_resolution_sources": ["explicit", "repo_policy", "git_remote"],
    "sync_default_scope": "effective_repo_scope_when_available",
    "mcp_protocol_version": "2025-11-25",
    "mcp_role": "optional read-only thin adapter over the CLI JSON/local retrieval contract",
    "mcp_tools": ["query", "get", "status"],
    "mcp_read_only": true,
    "not_exposed_to_mcp": [
      "sync",
      "init",
      "doctor",
      "eval",
      "embed",
      "delete",
      "update",
      "write",
      "hosted_provider"
    ],
    "mvp_sources": ["GitHub Issues", "GitHub issue comments"],
    "post_mvp_or_excluded_behavior": [
      "Wiki",
      "vector",
      "shared server",
      "write-back",
      "user-facing eval",
      "hosted provider default",
      "GHES release gate"
    ]
  },
  "schema_snapshots": [
    "docs/schemas/envelope.schema.json",
    "docs/schemas/error.schema.json",
    "docs/schemas/init-output.schema.json",
    "docs/schemas/sync-output.schema.json",
    "docs/schemas/query-result.schema.json",
    "docs/schemas/get-output.schema.json",
    "docs/schemas/status-output.schema.json",
    "docs/schemas/doctor-output.schema.json"
  ],
  "acceptance_snapshot": {
    "included_in_mvp_gate": [
      "AC-01",
      "AC-02",
      "AC-03",
      "AC-04",
      "AC-05",
      "AC-06",
      "AC-07",
      "AC-08",
      "AC-09",
      "AC-10",
      "AC-11",
      "AC-12",
      "AC-14",
      "AC-15",
      "AC-16",
      "AC-17",
      "AC-18",
      "AC-19",
      "AC-21",
      "AC-22",
      "AC-23",
      "AC-24",
      "AC-25",
      "AC-26",
      "AC-27",
      "AC-28"
    ],
    "excluded_from_mvp_gate": [
      {
        "id": "AC-13",
        "reason": "post-MVP vector/hybrid capability; BM25-only path remains the MVP gate"
      },
      {
        "id": "AC-20",
        "reason": "GHES is best-effort profile capability and not a release gate"
      }
    ]
  },
  "verification": [
    "Tantivy BM25-only path",
    "strict schema/envelope",
    "human CLI summaries",
    "init output",
    "get batch output",
    "MCP adapter parity smoke",
    "stdout cleanliness",
    "privacy no-egress",
    "DB/index permissions",
    "doctor output",
    "search eval result",
    "one-command Homebrew install",
    "cargo-dist plan/build",
    "generated Homebrew formula smoke",
    "release integrity attestations"
  ],
  "residual_risks": [
    "Wiki source connector is post-MVP",
    "vector and hosted provider quality improvements require an explicit future decision",
    "shared server and GitHub App token operations require separate ACL and audit design",
    "GHES remains best-effort until a dedicated compatibility pass",
    "Linux ARM64, Windows packages, and homebrew/core submission are later distribution targets",
    "Live dogfood against juicyjusung/qgh is manual and not a blocking CI gate"
  ]
}
